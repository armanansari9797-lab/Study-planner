{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Roadmap": {
      "title": "Roadmap",
      "description": "A learning roadmap generated for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "goal": { "type": "string" },
        "level": { "type": "string" },
        "availability": { "type": "integer" },
        "phases": { "type": "array" },
        "progress": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "goal", "phases"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/roadmaps/{roadmapId}": {
      "schema": "Roadmap",
      "description": "Generated roadmaps"
    }
  }
}
